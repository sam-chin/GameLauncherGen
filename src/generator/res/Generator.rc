STRINGTABLE
BEGIN
    IDS_APP_TITLE           "游戏启动器生成器"
    IDS_ERROR_TEMPLATE_NOT_FOUND "模板文件不存在"
    IDS_ERROR_INVALID_CONFIG "配置验证失败"
    IDS_SUCCESS_GENERATE    "启动器生成成功"
    IDS_STATUS_READY        "就绪"
    IDS_STATUS_GENERATING   "正在生成..."
    IDS_STATUS_PACKING      "正在打包..."
END

