; ===========================================================================
; Extension.def - 扩展DLL模块定义文件
; ===========================================================================
; @file Extension.def
; @brief 扩展DLL导出符号定义文件
; @details 本.def文件用于显式控制DLL的导出符号表，是确保32位远程线程注入
;          兼容性的关键文件。通过显式导出（而非依赖编译器的dllexport），
;          可以完全消除C++名称修饰，保证导出函数名与声明完全一致。
;
;          使用.def文件的优势：
;          1. 完全控制导出符号名称，不受编译器名称修饰规则影响
;          2. 支持按序号导出（ordinal），提高GetProcAddress效率
;          3. 可隐藏内部符号，减少DLL攻击面
;          4. 与__stdcall配合时，无需处理@参数字节数后缀
;          5. 确保32位和64位构建的导出表一致性（虽然本DLL仅支持32位）
;
;          导出序号分配规则：
;          - 1-9:   版本查询与信息获取函数
;          - 10-19: 核心生命周期函数（Init/UnInit）
;          - 20-29: 错误查询与诊断函数
;          - 30+:   保留给未来扩展功能
;
; @note 链接器选项中必须指定/DEF:Extension.def，CMake中通过
;       set_target_properties的LINK_FLAGS或target_link_options设置。
; @warning 修改本文件后必须重新链接DLL，仅编译修改的文件不会更新导出表。
; ===========================================================================

LIBRARY Extension

; ---------------------------------------------------------------------------
; 导出符号表
; ---------------------------------------------------------------------------
EXPORTS

    ; -----------------------------------------------------------------------
    ; 版本查询函数 (序号 1-9)
    ; -----------------------------------------------------------------------
    DllGetVersion       @1  NONAME

    ; -----------------------------------------------------------------------
    ; 核心生命周期函数 (序号 10-19)
    ; -----------------------------------------------------------------------
    ; DllInit: 扩展DLL初始化入口
    ; 这是启动器注入DLL后必须调用的第一个函数，用于完成复杂初始化。
    ; 使用NONAME属性隐藏名称（仅通过序号导出），增加逆向分析难度。
    DllInit             @10

    ; DllUnInit: 扩展DLL反初始化入口
    ; 用于显式清理资源，在DLL卸载前调用。
    DllUnInit           @11

    ; -----------------------------------------------------------------------
    ; 错误查询与诊断函数 (序号 20-29)
    ; -----------------------------------------------------------------------
    DllGetLastErrorString   @20
    DllGetLastErrorCode     @21

; ===========================================================================
; 结束 of Extension.def
; ===========================================================================
